  .ph-page-title { font-size: 11px; font-weight: 600; color: #0b1c30; }
  .ph-card   { background: #ffffff; border-radius: 10px; border: 1px solid #c4c5d7; }
  .ph-bottomnav { background: #ffffff; border-top: 1px solid #e0e4f0; display: flex; justify-content: space-around; padding: 6px 4px 10px; flex-shrink: 0; }
  .ph-nav-item { display: flex; flex-direction: column; align-items: center; gap: 2px; color: #747686; font-size: 9px; font-weight: 500; min-width: 48px; }
  .ph-nav-active { color: #0037b0; font-weight: 700; }
  .ph-nav-pill { background: #dee2ef; border-radius: 10px; padding: 2px 8px; display: flex; align-items: center; justify-content: center; }

  /* ── App sidebar active state ── */
  .app-sidebar-item.is-active {
    background: #dee2ef;
    color: #0037b0 !important;
    font-weight: 700;
  }

  /* ── Demo transitions ── */
  .fd-desktop, .fd-mobile {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .fd-desktop[data-active="false"],
  .fd-mobile[data-active="false"] {
    opacity: 0;
    pointer-events: none;
    transform: translateX(18px);
  }
  .fd-desktop[data-active="true"],
  .fd-mobile[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  /* ── Scrollbar hide ── */
  .fs-scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .fs-scrollbar-hide::-webkit-scrollbar { display: none; }
</style>

<script is:inline define:vars={{ featureDescriptions }}>
  (function () {
    const featureBtns   = document.querySelectorAll('#features-showcase .feature-btn');
    const dskDemos      = document.querySelectorAll('#features-showcase .fd-desktop');
    const mobDemos      = document.querySelectorAll('#features-showcase .fd-mobile');
    const sidebarItems  = document.querySelectorAll('#features-showcase .app-sidebar-item');
    const descriptionEl = document.getElementById('feature-description');

    function activate(featureId) {
      // ── Feature tab buttons ──
      featureBtns.forEach(b => {
        const style = b.getAttribute('data-btn-style');
        if (style === 'pill') {
          b.classList.remove('bg-primary', 'text-primary-foreground', 'active-feature');
          b.classList.add('bg-muted/80', 'text-muted-foreground');
        } else {
          b.classList.remove('bg-primary/10', 'font-medium', 'text-primary', 'active-feature');
          b.classList.add('text-foreground/70');
        }
      });
      document.querySelectorAll(`#features-showcase .feature-btn[data-feature="${featureId}"]`).forEach(b => {
        const style = b.getAttribute('data-btn-style');
        if (style === 'pill') {
          b.classList.remove('bg-muted/80', 'text-muted-foreground');
          b.classList.add('bg-primary', 'text-primary-foreground', 'active-feature');
        } else {
          b.classList.remove('text-foreground/70');
          b.classList.add('bg-primary/10', 'font-medium', 'text-primary', 'active-feature');
        }
      });

      // ── Desktop demos ──
      dskDemos.forEach(d => { d.setAttribute('data-active', 'false'); d.classList.add('hidden'); });
      const dsk = document.getElementById('dsk-' + featureId);
      if (dsk) { dsk.classList.remove('hidden'); requestAnimationFrame(() => dsk.setAttribute('data-active', 'true')); }

      // ── Mobile demos ──
      mobDemos.forEach(d => { d.setAttribute('data-active', 'false'); d.classList.add('hidden'); });
      const mob = document.getElementById('mob-' + featureId);
      if (mob) { mob.classList.remove('hidden'); requestAnimationFrame(() => mob.setAttribute('data-active', 'true')); }

      // ── App sidebar highlight ──
      sidebarItems.forEach(item => item.classList.remove('is-active'));
      const sidebarMatch = document.querySelector(`#features-showcase .app-sidebar-item[data-sidebar-feature="${featureId}"]`);
      if (sidebarMatch) sidebarMatch.classList.add('is-active');

      // ── Tip card description ──
      if (descriptionEl && featureDescriptions[featureId]) {
        descriptionEl.style.opacity = '0';
        setTimeout(() => { descriptionEl.textContent = featureDescriptions[featureId]; descriptionEl.style.opacity = '1'; }, 150);
      }
    }

    // Sidebar nav items also trigger tab switch
    sidebarItems.forEach(item => {
      item.addEventListener('click', () => {
        const fid = item.getAttribute('data-sidebar-feature');
        if (fid && featureDescriptions[fid]) activate(fid);
      });
    });

    featureBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const fid = btn.getAttribute('data-feature');
        if (fid) activate(fid);
      });
    });

    // Set initial active sidebar item
    activate('whatsapp');
  })();
</script>
