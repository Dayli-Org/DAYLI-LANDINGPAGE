---
import type { Locale } from '../i18n/ui';
import { getMessages } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale);

const features = [
  {
    id: 'whatsapp',
    icon: 'whatsapp',
    label: t.featuresShowcase?.whatsapp?.title || 'WhatsApp',
    description: t.featuresShowcase?.whatsapp?.description || 'Automatic reminders sent to clients via WhatsApp'
  },
  {
    id: 'calendar',
    icon: 'calendar',
    label: t.featuresShowcase?.calendar?.title || 'Smart Calendar',
    description: t.featuresShowcase?.calendar?.description || 'Manage your schedule and appointments easily'
  },
  {
    id: 'crm',
    icon: 'users',
    label: t.featuresShowcase?.crm?.title || 'Client CRM',
    description: t.featuresShowcase?.crm?.description || 'Manage your client relationships and history'
  },
  {
    id: 'ai',
    icon: 'bot',
    label: t.featuresShowcase?.ai?.title || 'AI Agent',
    description: t.featuresShowcase?.ai?.description || 'AI-powered assistant available 24/7 for your business'
  }
];

const featureDescriptions = Object.fromEntries(features.map(f => [f.id, f.description]));

const sidebarNav = [
  { id: 'calendar', label: 'לוח שנה',  iconPath: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>' },
  { id: 'whatsapp', label: 'וואטסאפ',  iconPath: '<path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/>' },
  { id: 'crm',      label: 'לקוחות',   iconPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { id: 'documents',label: 'מסמכים',   iconPath: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>' },
  { id: 'ai',       label: 'בינה מלאכ.',iconPath: '<path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>' },
];
---

<section id="features-showcase" class="relative py-20 sm:py-28">
  <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
    <div class="mx-auto max-w-3xl text-center mb-12">
      <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">
        <span class="text-ink">{t.featuresShowcase?.headline || 'Everything you need'}</span>
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        {t.featuresShowcase?.subheadline || 'Powerful features to run your business smoothly'}
      </p>
    </div>

    <div class="relative mx-auto max-w-5xl">
      <div class="overflow-hidden rounded-3xl border border-border bg-card shadow-glow">
        <div class="flex flex-col md:flex-row">

          <!-- ────────────────────────────────────────
               LEFT SIDEBAR  (shared for both views)
          ──────────────────────────────────────── -->
          <aside class="border-b md:border-b-0 md:border-e border-border bg-surface/50 md:w-[260px] md:flex-shrink-0 p-4 md:p-5">

            <!-- Mobile: horizontal scrollable tab pills -->
            <div class="flex gap-2 overflow-x-auto pb-2 md:hidden fs-scrollbar-hide">
              {features.map((f, i) => (
                <button
                  class:list={[
                    'flex-shrink-0 flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-all duration-200 feature-btn',
                    i === 0 ? 'bg-primary text-primary-foreground active-feature' : 'bg-muted/80 text-muted-foreground hover:bg-muted'
                  ]}
                  data-feature={f.id} data-btn-style="pill"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 shrink-0" aria-hidden="true">
                    {f.icon === 'whatsapp' && <path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21" />}
                    {f.icon === 'calendar' && (<><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></>)}
                    {f.icon === 'users'    && (<><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>)}
                    {f.icon === 'bot'      && (<><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></>)}
                  </svg>
                  <span>{f.label}</span>
                </button>
              ))}
            </div>

            <!-- Desktop: vertical list + tip card -->
            <div class="hidden md:flex md:flex-col">
              <div class="mb-4 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                {t.featuresShowcase?.navLabel || 'Features'}
              </div>
              <ul class="space-y-1">
                {features.map((f, i) => (
                  <li>
                    <button
                      class:list={[
                        'w-full flex items-center gap-2.5 rounded-lg px-2.5 py-2.5 text-sm transition-all duration-200 feature-btn',
                        i === 0 ? 'bg-primary/10 font-medium text-primary active-feature' : 'text-foreground/70 hover:bg-muted/60 hover:text-foreground'
                      ]}
                      data-feature={f.id} data-btn-style="list"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0" aria-hidden="true">
                        {f.icon === 'whatsapp' && <path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21" />}
                        {f.icon === 'calendar' && (<><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></>)}
                        {f.icon === 'users'    && (<><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>)}
                        {f.icon === 'bot'      && (<><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></>)}
                      </svg>
                      <span class="text-left">{f.label}</span>
                    </button>
                  </li>
                ))}
              </ul>
              <div class="mt-6 rounded-xl border border-border bg-background/60 p-4">
                <div class="text-xs font-medium text-muted-foreground mb-2">{t.featuresShowcase?.tipLabel || 'Pro Tip'}</div>
                <p class="text-sm text-foreground/80 transition-opacity duration-150" id="feature-description">{features[0].description}</p>
              </div>
            </div>
          </aside>

          <!-- ────────────────────────────────────────
               RIGHT PANEL
          ──────────────────────────────────────── -->
          <div class="flex-1 overflow-hidden">

            <!-- ══════════════════════════════════════
                 DESKTOP VIEW  (hidden on mobile)
                 Browser chrome + full app UI
            ══════════════════════════════════════ -->
            <div class="hidden md:flex md:flex-col h-full min-h-[480px]">

              <!-- Browser chrome bar -->
              <div class="flex h-9 items-center gap-1.5 border-b border-border bg-muted/50 px-4 flex-shrink-0">
                <span class="h-2.5 w-2.5 rounded-full bg-red-400/70"    aria-hidden="true"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-yellow-400/70" aria-hidden="true"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-green-400/70"  aria-hidden="true"></span>
                <span class="ms-3 text-xs text-muted-foreground">{t.featuresShowcase?.mockupUrl || 'app.dayli.io'}</span>
              </div>

              <!-- App shell: app-sidebar + content area -->
              <div class="flex flex-1 overflow-hidden bg-[#f8f9ff]" dir="rtl">

                <!-- App sidebar (always visible, active item updates via JS) -->
                <nav class="w-[150px] flex-shrink-0 bg-[#eff4ff] border-l border-[#e0e4f0] flex flex-col py-3 px-2 gap-1">
                  <div class="flex items-center gap-2 px-2 py-1 mb-3">
                    <div style="width:26px;height:26px;background:#0037b0;border-radius:7px;display:flex;align-items:center;justify-content:center;font-weight:800;color:white;font-size:11px;flex-shrink:0;">d</div>
                    <span style="font-weight:800;font-size:13px;color:#0037b0;letter-spacing:-0.3px;">dayli</span>
                  </div>
                  {sidebarNav.map(nav => (
                    <div
                      class="app-sidebar-item"
                      data-sidebar-feature={nav.id}
                      style="display:flex;align-items:center;gap:7px;padding:7px 8px;border-radius:9px;font-size:11px;color:#434655;cursor:pointer;transition:all .15s;"
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <Fragment set:html={nav.iconPath} />
                      </svg>
                      <span>{nav.label}</span>
                    </div>
                  ))}
                  <div class="mt-auto pt-3 border-t border-[#c4c5d7]/50 flex flex-col gap-1">
                    <div style="display:flex;align-items:center;gap:7px;padding:6px 8px;border-radius:9px;font-size:11px;color:#434655;">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                      <span>הגדרות</span>
                    </div>
                  </div>
                </nav>

                <!-- Desktop content area — demos swap here -->
                <div class="flex-1 overflow-hidden relative">

                  <!-- ── DESKTOP: WhatsApp ── -->
                  <div class="fd-desktop absolute inset-0 overflow-hidden" id="dsk-whatsapp" data-active="true">
                    <div class="h-full flex flex-col">
                      <!-- Page header -->
                      <div style="padding:14px 20px 12px;border-bottom:1px solid #e8eaf2;background:white;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
                        <div>
                          <h2 style="font-size:16px;font-weight:700;color:#0b1c30;">אוטומציות וואטסאפ</h2>
                          <p style="font-size:11px;color:#434655;margin-top:2px;">ניהול הודעות ותגובות אוטומטיות</p>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;">
                          <div style="background:#eff4ff;border:1px solid #c4c5d7;border-radius:8px;padding:6px 12px;font-size:11px;color:#434655;display:flex;align-items:center;gap:5px;">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                            <span>חיפוש...</span>
                          </div>
                        </div>
                      </div>

                      <!-- Toggle card + chat list side by side -->
                      <div style="flex:1;overflow:hidden;display:flex;gap:0;">

                        <!-- Chat list panel -->
                        <div style="width:260px;flex-shrink:0;border-left:1px solid #e8eaf2;overflow-y:auto;background:white;">
                          <!-- Auto-reply card -->
                          <div style="margin:10px 12px 8px;background:#f0f4ff;border-radius:10px;padding:10px 12px;border:1px solid #c4c5d7;display:flex;align-items:center;justify-content:space-between;gap:8px;">
                            <div>
                              <div style="font-size:11px;font-weight:600;color:#0b1c30;">תגובות אוטומטיות</div>
                              <div style="font-size:10px;color:#434655;margin-top:1px;">ענייה מחוץ לשעות הפעילות</div>
                            </div>
                            <div style="width:36px;height:20px;background:#0037b0;border-radius:10px;position:relative;flex-shrink:0;">
                              <div style="width:16px;height:16px;background:white;border-radius:50%;position:absolute;top:2px;right:2px;box-shadow:0 1px 3px rgba(0,0,0,.2);"></div>
                            </div>
                          </div>
                          <!-- Chats -->
                          {[
                            { init:'יכ', name:'יעל כהן',       msg:'היי, רציתי לקבוע פגישה',      time:'10:42', badge:2,    bg:'#eff4ff', active:true },
                            { init:'מל', name:'משה לוי',        msg:'הודעה אוטומטית נשלחה',        time:'אתמול', badge:0,    bg:'white',   active:false },
                            { init:'דא', name:'דוד אברהם',      msg:'מעולה, תודה רבה!',            time:'יום ב\'',badge:0,   bg:'white',   active:false },
                            { init:'חח', name:'חברת החשמל',     msg:'חשבונית מס\' 4582 נשלחה.',    time:'12/10', badge:0,    bg:'white',   active:false },
                          ].map(c => (
                            <div style={`display:flex;align-items:center;gap:10px;padding:10px 12px;border-bottom:1px solid #f0f0f0;background:${c.bg};cursor:pointer;`}>
                              <div style={`width:36px;height:36px;border-radius:50%;background:${c.active ? '#dee2ef' : '#eff0f5'};display:flex;align-items:center;justify-content:center;font-weight:700;color:${c.active ? '#0037b0' : '#5a5e69'};font-size:11px;flex-shrink:0;`}>{c.init}</div>
                              <div style="flex:1;min-width:0;">
                                <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:2px;">
                                  <span style={`font-size:12px;font-weight:${c.active ? '700' : '500'};color:#0b1c30;`}>{c.name}</span>
                                  <span style={`font-size:10px;color:${c.badge ? '#0037b0' : '#747686'};font-weight:${c.badge ? '600' : '400'};`}>{c.time}</span>
                                </div>
                                <div style="display:flex;justify-content:space-between;align-items:center;">
                                  <span style="font-size:10px;color:#434655;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:140px;">{c.msg}</span>
                                  {c.badge > 0 && <span style="background:#0037b0;color:white;border-radius:50%;min-width:17px;height:17px;font-size:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;padding:0 3px;">{c.badge}</span>}
                                </div>
                              </div>
                            </div>
                          ))}
                        </div>

                        <!-- Active chat conversation -->
                        <div style="flex:1;display:flex;flex-direction:column;background:#f8f9ff;">
                          <!-- Chat header -->
                          <div style="padding:12px 16px;border-bottom:1px solid #e8eaf2;background:white;display:flex;align-items:center;gap:10px;">
                            <div style="width:36px;height:36px;border-radius:50%;background:#dee2ef;display:flex;align-items:center;justify-content:center;font-weight:700;color:#0037b0;font-size:11px;">יכ</div>
                            <div>
                              <div style="font-size:13px;font-weight:700;color:#0b1c30;">יעל כהן</div>
                              <div style="font-size:10px;color:#25D366;display:flex;align-items:center;gap:3px;">
                                <div style="width:6px;height:6px;border-radius:50%;background:#25D366;"></div>
                                מחובר
                              </div>
                            </div>
                            <div style="margin-right:auto;display:flex;gap:8px;">
                              <div style="width:28px;height:28px;border-radius:8px;background:#eff4ff;display:flex;align-items:center;justify-content:center;">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#0037b0" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.62 2 2 0 0 1 3.62 1.44h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                              </div>
                            </div>
                          </div>
                          <!-- Messages -->
                          <div style="flex:1;overflow-y:auto;padding:14px 16px;display:flex;flex-direction:column;gap:8px;">
                            {[
                              { type:'recv', text:'היי, רציתי לקבוע פגישה למחר בבוקר. האם יש פנוי?', time:'10:42' },
                              { type:'sent', text:'היי יעל! כמובן, יש לי פנוי מחר בין 10:00 ל-13:00. איזה שעה מתאימה לך?', time:'10:43', auto:true },
                              { type:'recv', text:'מושלם, 11:00 מתאים לי', time:'10:44' },
                              { type:'sent', text:'הי יעל, תזכורת לגבי התור שלך מחר בשעה 11:00 ✓', time:'10:45' },
                            ].map(m => (
                              <div style={`display:flex;justify-content:${m.type === 'sent' ? 'flex-start' : 'flex-end'};`}>
                                <div style={`max-width:72%;padding:8px 12px;border-radius:${m.type === 'sent' ? '14px 14px 14px 3px' : '14px 14px 3px 14px'};background:${m.type === 'sent' ? (m.auto ? '#e0f2e9' : '#DCF8C6') : 'white'};border:${m.type === 'recv' ? '1px solid #e8eaf2' : 'none'};box-shadow:0 1px 2px rgba(0,0,0,.06);`}>
                                  {m.auto && <div style="font-size:9px;color:#0037b0;font-weight:600;margin-bottom:3px;display:flex;align-items:center;gap:3px;"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#0037b0" stroke-width="2"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/></svg>אוטומטי</div>}
                                  <p style="font-size:11px;color:#0b1c30;line-height:1.45;">{m.text}</p>
                                  <div style={`font-size:9px;color:#747686;margin-top:3px;text-align:${m.type === 'sent' ? 'right' : 'left'};`}>{m.time}</div>
                                </div>
                              </div>
                            ))}
                          </div>
                          <!-- Input -->
                          <div style="padding:10px 16px;border-top:1px solid #e8eaf2;background:white;display:flex;gap:8px;align-items:center;">
                            <div style="flex:1;background:#f8f9ff;border:1px solid #c4c5d7;border-radius:20px;padding:8px 14px;font-size:11px;color:#747686;">הקלד הודעה...</div>
                            <div style="width:32px;height:32px;border-radius:50%;background:#0037b0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- ── DESKTOP: Calendar ── -->
                  <div class="fd-desktop absolute inset-0 overflow-hidden hidden" id="dsk-calendar" data-active="false">
                    <div class="h-full flex flex-col">
                      <div style="padding:14px 20px 12px;border-bottom:1px solid #e8eaf2;background:white;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
                        <div style="display:flex;align-items:center;gap:8px;">
                          <h2 style="font-size:16px;font-weight:700;color:#0b1c30;">נובמבר 2023</h2>
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#434655" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                        </div>
                        <div style="display:flex;gap:6px;">
                          <div style="background:#eff4ff;border:1px solid #c4c5d7;border-radius:8px;padding:6px 10px;font-size:11px;color:#434655;">חיפוש</div>
                          <div style="background:#eff4ff;border:1px solid #c4c5d7;border-radius:8px;padding:6px 10px;font-size:11px;color:#434655;">סינון</div>
                          <div style="background:#0037b0;border-radius:8px;padding:6px 12px;font-size:11px;color:white;font-weight:600;">+ פגישה חדשה</div>
                        </div>
                      </div>
                      <!-- Date chips -->
                      <div style="display:flex;gap:8px;padding:12px 20px;border-bottom:1px solid #e8eaf2;background:white;flex-shrink:0;">
                        {[{d:'12',l:'א\'',dot:false,cur:false},{d:'13',l:'ב\'',dot:true,cur:true},{d:'14',l:'ג\'',dot:true,cur:false},{d:'15',l:'ד\'',dot:false,cur:false,dim:true},{d:'16',l:'ה\'',dot:false,cur:false},{d:'17',l:'ו\'',dot:true,cur:false},{d:'18',l:'ש\'',dot:false,cur:false}].map(day => (
