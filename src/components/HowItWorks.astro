---
import type { Locale } from '../i18n/ui';
import { getMessages } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale);
---

<section class="section-container py-16 md:py-20">
  <h2 class="section-title">{t.howItWorks.title}</h2>
  <ol class="mt-10 grid gap-6 md:grid-cols-3">
    {
      t.howItWorks.steps.map((step, index) => (
        <li class="rounded-2xl border border-primary/10 bg-white p-6 shadow-card">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-primary text-lg font-bold text-white">
            {index + 1}
          </span>
          <h3 class="mt-4 text-xl font-semibold text-ink">{step.title}</h3>
          <p class="mt-2 text-ink/75">{step.description}</p>
        </li>
      ))
    }
  </ol>
</section>
