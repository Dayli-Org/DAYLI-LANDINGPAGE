---
import type { Locale } from '../i18n/ui';
import {
  getLocalePath,
  getMessages,
  localeLabels,
  localeShortLabels,
  locales,
} from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale);

const navLinks = [
  { href: '#features', label: t.nav.features },
  { href: '#pricing', label: t.nav.pricing },
  { href: '#contact', label: t.nav.contact },
];
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-background/70 backdrop-blur-xl">
  <div class="mx-auto flex h-14 max-w-7xl items-center gap-2 px-3 sm:h-16 sm:gap-4 sm:px-5 md:px-8">
    <!-- Mobile menu -->
    <details class="header-menu relative md:hidden">
      <summary
        class="header-menu__trigger inline-flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-full border border-border bg-card text-foreground transition-colors duration-200 hover:bg-accent [&::-webkit-details-marker]:hidden"
        aria-label={t.nav.menu}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
          <path d="M4 5h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 19h16"></path>
        </svg>
      </summary>
      <div class="header-menu__panel absolute start-0 top-[calc(100%+0.5rem)] z-50 min-w-[12rem] rounded-2xl border border-border bg-card p-2 shadow-glow">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="block cursor-pointer rounded-xl px-3 py-2.5 text-sm font-medium text-foreground transition-colors duration-200 hover:bg-accent"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </details>

    <a
      href={getLocalePath(locale)}
      class="flex min-w-0 shrink cursor-pointer items-center rounded-lg p-1 transition-opacity duration-200 hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      aria-label="Dayli"
    >
      <img
        src={`${import.meta.env.BASE_URL}/dayli-logo.png`}
        alt="Dayli"
        width="160"
        height="48"
        class="h-6 w-auto max-w-[5.5rem] object-contain sm:h-7 sm:max-w-none"
        decoding="async"
      />
    </a>

    <nav class="hidden min-w-0 flex-1 items-center justify-center gap-8 text-sm text-muted-foreground md:flex" aria-label="Main">
      {
        navLinks.map((link) => (
          <a href={link.href} class="cursor-pointer whitespace-nowrap transition-colors duration-200 hover:text-foreground">
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="ms-auto flex min-w-0 shrink-0 items-center gap-1 sm:gap-2">
      <!-- Mobile: compact language dropdown -->
      <details class="header-lang relative md:hidden">
        <summary
          class="header-lang__trigger inline-flex h-8 cursor-pointer list-none items-center gap-1 rounded-full border border-border bg-card px-2 text-xs font-medium text-foreground transition-colors duration-200 hover:bg-accent [&::-webkit-details-marker]:hidden"
          aria-label={t.nav.language}
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 shrink-0 text-muted-foreground" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
            <path d="M2 12h20"></path>
          </svg>
          <span>{localeShortLabels[locale]}</span>
        </summary>
        <div class="header-lang__panel absolute end-0 top-[calc(100%+0.5rem)] z-50 min-w-[9rem] rounded-2xl border border-border bg-card p-1.5 shadow-glow">
          {
            locales.map((loc) => (
              <a
                href={getLocalePath(loc)}
                class:list={[
                  'flex cursor-pointer items-center justify-between gap-3 rounded-xl px-3 py-2 text-sm transition-colors duration-200',
                  loc === locale
                    ? 'bg-foreground font-medium text-background'
                    : 'text-foreground hover:bg-accent',
                ]}
                hreflang={loc}
                lang={loc}
              >
                <span>{localeLabels[loc]}</span>
                <span class="text-xs opacity-70">{localeShortLabels[loc]}</span>
              </a>
            ))
          }
        </div>
      </details>

      <!-- Desktop: language pills -->
      <div
        class="hidden rounded-full border border-border bg-card p-0.5 md:flex"
        role="group"
        aria-label={t.nav.language}
      >
        {
          locales.map((loc) => (
            <a
              href={getLocalePath(loc)}
              class:list={[
                'cursor-pointer rounded-full px-3 py-1 text-sm font-medium transition-colors duration-200',
                loc === locale
                  ? 'bg-foreground text-background'
                  : 'text-muted-foreground hover:text-foreground',
              ]}
              hreflang={loc}
              lang={loc}
            >
              {localeLabels[loc]}
            </a>
          ))
        }
      </div>

      <a href="#pricing" class="btn-nav whitespace-nowrap">
        <span class="sm:hidden">{t.nav.ctaShort}</span>
        <span class="hidden sm:inline">{t.nav.cta}</span>
      </a>
    </div>
  </div>
</header>

<script>
  function closeDetailsOnOutsideClick(event: MouseEvent) {
    const target = event.target as HTMLElement | null;
    if (!target) return;

    document.querySelectorAll('details.header-menu[open], details.header-lang[open]').forEach((details) => {
      if (!details.contains(target)) {
        details.removeAttribute('open');
      }
    });
  }

  function closeDetailsOnNavigate() {
    document.querySelectorAll('details.header-menu[open], details.header-lang[open]').forEach((details) => {
      details.removeAttribute('open');
    });
  }

  document.addEventListener('click', closeDetailsOnOutsideClick);
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeDetailsOnNavigate();
  });
  window.addEventListener('hashchange', closeDetailsOnNavigate);
</script>

<style>
  .header-menu[open] .header-menu__trigger,
  .header-lang[open] .header-lang__trigger {
    background-color: var(--accent);
  }
</style>
