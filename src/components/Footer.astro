---
import type { Locale } from '../i18n/ui';
import { getMessages } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale);
---

<footer class="footer">
  <div class="footer__inner section-container">

    <div class="footer__brand">
      <img
        src={`${import.meta.env.BASE_URL}/dayli-logo.png`}
        alt="Dayli"
        width="32"
        height="32"
        class="footer__logo"
      />
      <p class="footer__tagline">{t.footer.tagline}</p>
    </div>

    <div class="footer__contact">
      <p class="footer__rights">{t.footer.rights}</p>
      <div class="footer__links">
        <a href="tel:+972505391115" class="footer__link" dir="ltr">‎+972 50-539-1115</a>
        <a href="mailto:daylicrm@gmail.com" class="footer__link">daylicrm@gmail.com</a>
      </div>
    </div>

  </div>
</footer>

<style>
  .footer {
    background-color: var(--card);
    border-block-start: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    padding-block: var(--sp-10);
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    min-width: 0;
  }

  .footer__logo {
    height: 1.75rem;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
  }

  .footer__tagline {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    margin: 0;
    white-space: nowrap;
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--sp-1);
    min-width: 0;
  }

  .footer__rights {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    margin: 0;
  }

  .footer__links {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    flex-wrap: nowrap;
  }

  .footer__link {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color var(--transition);
    white-space: nowrap;
  }

  .footer__link:hover {
    color: var(--foreground);
  }

  @media (max-width: 640px) {
    .footer__inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer__contact {
      align-items: center;
    }

    .footer__links {
      flex-wrap: wrap;
      justify-content: center;
    }

    .footer__tagline {
      white-space: normal;
    }
  }
</style>
