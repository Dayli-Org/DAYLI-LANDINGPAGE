---
import type { Locale } from '../i18n/ui';
import { getMessages } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale);
---

<footer class="border-t border-border/60 bg-card py-10">
  <div class="section-container flex flex-col items-center justify-between gap-4 sm:flex-row">
    <div class="flex items-center gap-3">
      <img src="/dayli-logo.png" alt="Dayli" width="32" height="32" class="h-7 w-auto object-contain" />
      <p class="text-sm text-muted-foreground">
        <span class="font-semibold text-ink">Dayli</span>
        {t.footer.tagline}
      </p>
    </div>
    <div class="flex flex-col items-center gap-1 text-sm text-muted-foreground sm:items-end">
      <p>{t.footer.rights}</p>
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
        <a href="tel:+972505391115" class="hover:text-ink transition-colors" dir="ltr">‎+972 50-539-1115</a>
        <a href="mailto:daylicrm@gmail.com" class="hover:text-ink transition-colors">daylicrm@gmail.com</a>
      </div>
    </div>
  </div>
</footer>
