---
import type { Locale } from '../i18n/ui';
import { arrowIconClass, getMessages, isRtl } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale);
const rtl = isRtl(locale);

const calendarDays = Array.from({ length: 28 }, (_, i) => i + 1);
const primaryDays = new Set([4, 10, 18, 23]);
const brandDay = 15;
const appointmentTimes = ['10:20', '10:30', '10:40'];
---

<section id="top" class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 bg-hero" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 grid-bg" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-5 pb-24 pt-20 sm:px-8 sm:pb-32 sm:pt-28">
    <div class="mx-auto max-w-3xl text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-border/80 bg-card/60 px-3.5 py-1.5 text-xs font-medium text-muted-foreground shadow-sm backdrop-blur">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 text-primary" aria-hidden="true">
          <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path>
          <path d="M20 2v4"></path>
          <path d="M22 4h-4"></path>
          <circle cx="4" cy="20" r="2"></circle>
        </svg>
        {t.hero.badge}
      </div>

      <h1 class="mt-6 font-display text-5xl font-extrabold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl">
        <span class="text-ink">{t.hero.headlineLine1}</span><br />
        <span class="text-gradient">{t.hero.headlineLine2}</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground">
        {t.hero.subheadline}
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href="#pricing" class="group btn-primary">
          {t.hero.primaryCta}
          {
            rtl ? (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={arrowIconClass(locale)} aria-hidden="true">
                <path d="m12 19-7-7 7-7"></path>
                <path d="M19 12H5"></path>
              </svg>
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={arrowIconClass(locale)} aria-hidden="true">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            )
          }
        </a>
        <a href="#features" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-primary" aria-hidden="true">
            <path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"></path>
          </svg>
          {t.hero.secondaryCta}
        </a>
      </div>

      <p class="mt-5 text-xs text-muted-foreground">{t.hero.proof}</p>
    </div>

    <div class="relative mx-auto mt-16 max-w-5xl">
      <div class="overflow-hidden rounded-3xl border border-border bg-card shadow-glow">
        <div class="flex h-9 items-center gap-1.5 border-b border-border bg-muted/50 px-4">
          <span class="h-2.5 w-2.5 rounded-full bg-red-400/70" aria-hidden="true"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-yellow-400/70" aria-hidden="true"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-green-400/70" aria-hidden="true"></span>
          <span class="ms-3 text-xs text-muted-foreground">{t.hero.mockupUrl}</span>
        </div>

        <div class="grid min-h-[360px] md:grid-cols-[260px_1fr]">
          <aside class="hidden border-e border-border bg-surface/50 p-5 md:block">
            <div class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
              {t.hero.mockupNavLabel}
            </div>
            <ul class="space-y-1">
              {
                t.hero.mockupNav.map((item) => (
                  <li
                    class:list={[
                      'flex items-center gap-2.5 rounded-lg px-2.5 py-2 text-sm',
                      item.active
                        ? 'bg-primary/10 font-medium text-primary'
                        : 'text-foreground/70',
                    ]}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0" aria-hidden="true">
                      {item.active ? (
                        <>
                          <path d="M8 2v4"></path>
                          <path d="M16 2v4"></path>
                          <rect width="18" height="18" x="3" y="4" rx="2"></rect>
                          <path d="M3 10h18"></path>
                        </>
                      ) : (
                        <path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"></path>
                      )}
                    </svg>
                    {item.label}
                  </li>
                ))
              }
            </ul>
          </aside>

          <div class="p-6 sm:p-8">
            <div class="mb-5 flex items-center justify-between">
              <div>
                <div class="text-xs text-muted-foreground">{t.hero.mockupSubtitle}</div>
                <div class="mt-0.5 text-lg font-semibold">{t.hero.mockupTitle}</div>
              </div>
              <div class="h-8 w-8 rounded-full bg-brand" aria-hidden="true"></div>
            </div>

            <div class="grid grid-cols-7 gap-1.5">
              {
                calendarDays.map((day) => (
                  <div
                    class:list={[
                      'flex aspect-square items-center justify-center rounded-md text-xs',
                      day === brandDay
                        ? 'bg-brand font-semibold text-primary-foreground shadow-brand'
                        : primaryDays.has(day)
                          ? 'bg-primary/10 font-medium text-primary'
                          : 'bg-muted/60 text-muted-foreground',
                    ]}
                  >
                    {day}
                  </div>
                ))
              }
            </div>

            <div class="mt-6 space-y-2">
              {
                appointmentTimes.map((time) => (
                  <div class="flex items-center gap-3 rounded-xl border border-border bg-background/60 p-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand/10">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-primary" aria-hidden="true">
                        <path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"></path>
                      </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="h-2.5 w-32 rounded bg-muted"></div>
                      <div class="mt-2 h-2 w-44 rounded bg-muted/60"></div>
                    </div>
                    <div class="text-xs text-muted-foreground">{time}</div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
